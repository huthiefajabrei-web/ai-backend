# ==========================================
# AI Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# API Keys (required)
RUNPOD_API_KEY=your_runpod_key
RUNPOD_ENDPOINT_ID=your_endpoint_id
GEMINI_API_KEY=your_gemini_key
VEO_API_KEY=your_veo_key

# Supabase Postgres (required for auth/sessions/content tables)
# Use the Transaction Pooler or direct Postgres URL from Supabase project settings.
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Public/Server API URLs
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000
ADMIN_EMAILS=admin@example.com

# Optional if you enable Supabase JS auth in frontend later
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Kling AI Video (required for video journey)
KLING_API_KEY=your_kling_api_key
KLING_SECRET_KEY=your_kling_secret_key
# Optional: Kling video model. Default kling-v2-6 (لنقطة api-singapore). إن رُفض يُستخدم الاحتياطي تلقائياً.
# قيم محتملة: kling-v2-6, kling-v1-1, kling-v1 (حسب الحزمة/المنطقة مثل اليمن)
# KLING_VIDEO_MODEL=kling-v2-6
# KLING_VIDEO_MODEL_FALLBACK=kling-v1-1

# Optional: Veo Video Model
# - veo-3.1-generate-preview (default, best quality)
# - veo-3.1-fast-generate-preview (faster generation)
# VEO_MODEL=veo-3.1-generate-preview
